-- [[ 4. LOGIKA TARGET TERDEKAT ]] --
local function GetClosestPlayer()
    local MaximumDistance = Config.FOV_Radius
    local Target = nil
    
    for _, v in ipairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") and v.Character:FindFirstChildOfClass("Humanoid") and v.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
            local ScreenPoint, OnScreen = Camera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
            if OnScreen then
                local MousePos = UserInputService:GetMouseLocation()
                local VectorDistance = (Vector2.new(ScreenPoint.X, ScreenPoint.Y) - MousePos).Magnitude
                if VectorDistance < MaximumDistance then
                    MaximumDistance = VectorDistance
                    Target = v
                end
            end
        end
    end
    return Target
end

-- [[ 5. CORE ENGINE ESP ]] --
local function BuildESP(TargetPlayer)
    local Box = Drawing.new("Square")
    Box.Visible = false
    Box.Color = Color3.fromRGB(255, 255, 255)
    Box.Thickness = 1
    Box.Filled = false

    local HealthBar = Drawing.new("Square")
    HealthBar.Visible = false
    HealthBar.Color = Color3.fromRGB(0, 255, 0)
    HealthBar.Thickness = 1
    HealthBar.Filled = true

    local Connection
    Connection = RunService.RenderStepped:Connect(function()
        if Config.ESP_Enabled and TargetPlayer and TargetPlayer.Character and TargetPlayer.Character:FindFirstChild("HumanoidRootPart") and TargetPlayer.Character:FindFirstChildOfClass("Humanoid") and TargetPlayer.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
            local RootPart = TargetPlayer.Character.HumanoidRootPart
            local Humanoid = TargetPlayer.Character:FindFirstChildOfClass("Humanoid")
            local Position, OnScreen = Camera:WorldToViewportPoint(RootPart.Position)

            if OnScreen then
                local Scale = 1 / (Position.Z * math.tan(math.rad(Camera.FieldOfView / 2))) * 1000
                local BoxX = Position.X - (Scale / 2)
                local BoxY = Position.Y - (Scale / 2)

                Box.Size = Vector2.new(Scale, Scale)
                Box.Position = Vector2.new(BoxX, BoxY)
                Box.Visible = true

                local HealthPercentage = Humanoid.Health / Humanoid.MaxHealth
                HealthBar.Size = Vector2.new(3, Scale * HealthPercentage)
                HealthBar.Position = Vector2.new(BoxX - 6, BoxY + (Scale - (Scale * HealthPercentage)))
                HealthBar.Color = Color3.fromRGB(255 - (255 * HealthPercentage), 255 * HealthPercentage, 0)
                HealthBar.Visible = true
            else
                Box.Visible = false
                HealthBar.Visible = false
            end
        else
            Box.Visible = false
            HealthBar.Visible = false
            if not TargetPlayer or not TargetPlayer.Parent then
                Box:Remove()
                HealthBar:Remove()
                Connection:Disconnect()
            end
        end
    end)
end

for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer then BuildESP(p) end end
Players.PlayerAdded:Connect(function(p) if p ~= LocalPlayer then BuildESP(p) end end)

-- [[ 6. HOOK METATABLE ENGINE ]] --
local mt = getrawmetatable(game)
local oldIndex = mt.__index
local oldNamecall = mt.__namecall
setreadonly(mt, false)

mt.__index = newcclosure(function(self, index)
    if Config.Aimbot_Type == "Silent Aim" and not checkcaller() then
        if self == PlayerMouse and (index == "Hit" or index == "Target") then
            local target = GetClosestPlayer()
            local targetBody = target and target.Character and (target.Character:FindFirstChild("UpperTorso") or target.Character:FindFirstChild("HumanoidRootPart"))
            if targetBody then
                return index == "Hit" and targetBody.CFrame or targetBody
            end
        end
    end
    return oldIndex(self, index)
end)

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    if Config.Aimbot_Type == "Silent Aim" and not checkcaller() then
        if method == "Raycast" and self == workspace then
            local target = GetClosestPlayer()
            local targetBody = target and target.Character and (target.Character:FindFirstChild("UpperTorso") or target.Character:FindFirstChild("HumanoidRootPart"))
            
            if targetBody then
                local origin = args[2] -- Gunakan indeks array langsung untuk stabilitas parameter
                args[3] = (targetBody.Position - origin).Unit * 1000
                
                if Config.Wallbang_Enabled then
                    local params = args[4] or RaycastParams.new()
                    params.FilterType = Enum.RaycastFilterType.Exclude
                    local IgnoreList = {LocalPlayer.Character, workspace:FindFirstChild("Terrain")}
                    for _, obj in ipairs(workspace:GetChildren()) do
                        if obj.Name ~= "Players" and obj ~= target.Character then
                            table.insert(IgnoreList, obj)
                        end
                    end
                    params.FilterDescendantsInstances = IgnoreList
                    args[4] = params
                end
            end
            
        elseif (method == "FindPartOnRay" or method == "FindPartOnRayWithIgnoreList") and Config.Wallbang_Enabled then
            local target = GetClosestPlayer()
            local targetBody = target and target.Character and (target.Character:FindFirstChild("UpperTorso") or target.Character:FindFirstChild("HumanoidRootPart"))
            
            if targetBody then
                local origin = args[1].Origin
                args[1] = Ray.new(origin, (targetBody.Position - origin).Unit * 1000)
                
                if method == "FindPartOnRayWithIgnoreList" then
                    local IgnoreList = args[2] or {}
                    for _, obj in ipairs(workspace:GetChildren()) do
                        if obj.Name ~= "Players" and obj ~= target.Character then
                            table.insert(IgnoreList, obj)
                        end
                    end
                    args[2] = IgnoreList
                end
            end
        end
    end
    
    setnamecallmethod(method)
    return oldNamecall(self, unpack(args))
end)

setreadonly(mt, true)
