-- 2. FUNGSI CHECK KEY
CheckBtn.MouseButton1Click:Connect(function()
    if Box.Text == CorrectKey then
        if writefile then
            writefile(FileName, Box.Text) -- Simpen key biar besok gratis
        end
        ScreenGui:Destroy()
        Start_YutaHub()
    else
        Box.Text = ""
        Box.PlaceholderText = "INVALID KEY!"
        Box.PlaceholderColor3 = Color3.new(1, 0, 0)
    end
end)

-- 3. CEK APAKAH SUDAH ADA KEY TERSIMPAN
local function Init()
    if isfile and isfile(FileName) then
        local saved = readfile(FileName)
        if saved == CorrectKey then
            Start_YutaHub()
            return
        end
    end
    ScreenGui.Enabled = true -- Munculin UI kalau belum ada key
end

Init()
