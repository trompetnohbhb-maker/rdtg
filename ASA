-- // 1. LOADING ORION LIBRARY (Sangat Ringan & Mendukung Layar Sentuh HP)
local OrionLib = loadstring(game:HttpGet("githubusercontent.com"))()

-- // 2. MEMBUAT JENDELA UTAMA GUI
local Window = OrionLib:MakeWindow({
    Name = "FF UNDERGROUND - MULTI PLATFORM", 
    HidePremium = false, 
    SaveConfig = true, 
    ConfigFolder = "OrionTest"
})

-- // 3. KONFIGURASI GLOBAL
getgenv().CheatConfig = {
    UndergroundEnabled = false,
    SilentAimEnabled = false,
    Depth = -25
}

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")

-- // 4. MEMBUAT HALAMAN DAN UTILITY
local Tab = Window:MakeTab({Name = "Main Fitur", Icon = "rbxassetid://4483345998", PremiumOnly = false})

-- TOGGLE UNDERGROUND (UNTUK LAPTOP & HP)
Tab:AddToggle({
    Name = "Underground Hack (FF Style)",
    Default = false,
    Callback = function(Value)
        getgenv().CheatConfig.UndergroundEnabled = Value
    end    
})

-- TOGGLE SILENT AIM
Tab:AddToggle({
    Name = "Silent Aim (Tembus Tanah)",
    Default = false,
    Callback = function(Value)
        getgenv().CheatConfig.SilentAimEnabled = Value
    end    
})

-- SLIDER KEDALAMAN TANAH
Tab:AddSlider({
    Name = "Kedalaman Posisi",
    Min = -50,
    Max = -10,
    Default = -25,
    Color = Color3.fromRGB(255,255,255),
    Increment = 1,
    ValueName = "Studs",
    Callback = function(Value)
        getgenv().CheatConfig.Depth = value
    end    
})

-- // 5. LOGIKA UTAMA (SINKRONISASI FISIKA MULTI-PLATFORM)
RunService.Heartbeat:Connect(function()
    if not getgenv().CheatConfig.UndergroundEnabled then return end

    -- Menurunkan Karakter Kita Sendiri ke Bawah Tanah
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        LocalPlayer.Character.HumanoidRootPart.CFrame = LocalPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0, getgenv().CheatConfig.Depth, 0)
    end

    -- Menurunkan Hitbox Semua Musuh (Hanya Terlihat di Layar Laptop/HP Anda)
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local Root = player.Character.HumanoidRootPart
            Root.CFrame = CFrame.new(Root.Position.X, getgenv().CheatConfig.Depth, Root.Position.Z)
        end
    end
end)

-- // 6. METATABLE HOOKING UNIVERSAL UNTUK RE-ROUTING PELURU
local RawMetatable = getrawmetatable(game)
local OldNamecall = RawMetatable.__namecall
setreadonly(RawMetatable, false)

RawMetatable.__namecall = newcclosure(function(Object, ...)
    local Method = getnamecallmethod()
    local Args = {...}

    if getgenv().CheatConfig.SilentAimEnabled and (Method == "FindPartOnRayWithIgnoreList" or Method == "Raycast") then
        -- Memaksa peluru mengabaikan objek tanah (Bypass Collision)
        table.insert(Args, Workspace:FindFirstChild("Map") or Workspace.Terrain)
        return OldNamecall(Object, unpack(Args))
    end

    return OldNamecall(Object, ...)
end)
setreadonly(RawMetatable, true)

-- NOTIFIKASI AKTIF
OrionLib:Init()
