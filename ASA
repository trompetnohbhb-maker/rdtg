-- GUI Anti-AFK Fix + Timer Menempel
local ScreenGui = Instance.new("ScreenGui")
local MainButton = Instance.new("TextButton")
local TimeLabel = Instance.new("TextLabel")
local UICornerBtn = Instance.new("UICorner")
local UICornerLbl = Instance.new("UICorner")

-- Setup GUI
ScreenGui.Name = "AntiAFK_Fixed"
ScreenGui.Parent = game:GetService("CoreGui")
ScreenGui.ResetOnSpawn = false

-- Tombol Utama
MainButton.Name = "ToggleButton"
MainButton.Parent = ScreenGui
MainButton.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
MainButton.Position = UDim2.new(0.1, 0, 0.4, 0)
MainButton.Size = UDim2.new(0, 150, 0, 45)
MainButton.Font = Enum.Font.SourceSansBold
MainButton.Text = "Anti-AFK: OFF"
MainButton.TextColor3 = Color3.fromRGB(255, 255, 255)
MainButton.TextSize = 18
MainButton.Draggable = true -- Bisa digeser

UICornerBtn.CornerRadius = UDim.new(0, 8)
UICornerBtn.Parent = MainButton

-- Label Timer (Ditaruh di dalam MainButton agar nempel terus)
TimeLabel.Name = "TimeLabel"
TimeLabel.Parent = MainButton
TimeLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
TimeLabel.BackgroundTransparency = 0.4
TimeLabel.Position = UDim2.new(0, 0, 1, 5) -- 5 pixel di bawah tombol
TimeLabel.Size = UDim2.new(1, 0, 0, 30)
TimeLabel.Font = Enum.Font.SourceSans
TimeLabel.Text = "Waktu: 00:00:00"
TimeLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
TimeLabel.TextSize = 16

UICornerLbl.CornerRadius = UDim.new(0, 8)
UICornerLbl.Parent = TimeLabel

local running = false
local seconds = 0
local VirtualUser = game:GetService("VirtualUser")

-- Fungsi Format Waktu
local function formatTime(sc)
    local hours = math.floor(sc / 3600)
    local mins = math.floor((sc % 3600) / 60)
    local secs = sc % 60
    return string.format("Waktu: %02d:%02d:%02d", hours, mins, secs)
end

-- Loop Detik
task.spawn(function()
    while true do
        if running then
            seconds = seconds + 1
            TimeLabel.Text = formatTime(seconds)
        end
        task.wait(1)
    end
end)

-- Fungsi Anti-AFK (Mencegah Kick)
game:GetService("Players").LocalPlayer.Idled:Connect(function()
    if running then
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end
end)

-- Logika Klik Tombol
MainButton.MouseButton1Click:Connect(function()
    running = not running
    if running then
        MainButton.Text = "Anti-AFK: ON"
        MainButton.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
    else
        seconds = 0 -- Reset waktu saat dimatikan
        MainButton.Text = "Anti-AFK: OFF"
        MainButton.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        TimeLabel.Text = "Waktu: 00:00:00"
    end
end)
