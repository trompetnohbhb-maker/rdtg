-- [[ 1. DETEKSI TEMPAT PENEMPATAN UTAMA ]]
local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Target wadah yang paling stabil untuk menampung GUI eksternal
local TargetParent = nil
local pcallSuccess = pcall(function()
    if CoreGui and CoreGui:ClassName() == "CoreGui" then
        TargetParent = CoreGui
    end
end)

-- Jika executor dikunci oleh sistem keamanan CoreGui, lempar paksa ke PlayerGui agar TETAP MUNCUL
if not pcallSuccess or not TargetParent then
    TargetParent = LocalPlayer:WaitForChild("PlayerGui")
end

-- Bersihkan sisa UI gagal sebelumnya agar tidak menumpuk di memori
if TargetParent:FindFirstChild("Yuta_Murni_Canvas") then 
    TargetParent.Yuta_Murni_Canvas:Destroy() 
end

