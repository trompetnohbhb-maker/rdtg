-- [[ 7. LOGIKA GAME: AMBLAS KE BAWAH TANAH (VISUAL SAJA) ]] --
RunService.RenderStepped:Connect(function()
    if not getgenv().VisualUnderground then return end

    -- Menurunkan visual tubuh kita sendiri
    if Players.LocalPlayer.Character then
        Players.LocalPlayer.Character:TranslateBy(OffsetKedalaman)
    end

    -- Menurunkan visual seluruh musuh
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= Players.LocalPlayer and player.Character then
            player.Character:TranslateBy(OffsetKedalaman)
        end
    end
end)

-- [[ 8. LOGIKA GAME: SILENT AIM HIT TARGET ASLI (METATABLE) ]] --
local RawMetatable = getrawmetatable(game)
local OldNamecall = RawMetatable.__namecall
setreadonly(RawMetatable, false)

RawMetatable.__namecall = newcclosure(function(Object, ...)
    local Method = getnamecallmethod()
    local Args = {...}

    if getgenv().SilentAim and (Method == "FindPartOnRayWithIgnoreList" or Method == "Raycast" or Method == "FireServer") then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= Players.LocalPlayer and player.Character and player.Character:FindFirstChild("Head") then
                local TargetHead = player.Character.Head.Position
                if Method == "Raycast" then
                    Args = (TargetHead - Args).Unit * 1000
                end
                return OldNamecall(Object, unpack(Args))
            end
        end
    end
    return OldNamecall(Object, ...)
end)
setreadonly(RawMetatable, true)
